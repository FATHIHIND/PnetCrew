{
  "name": "smartcontext-doc-server",
  "version": "1.0.0",
  "description": "Serveur API pour SmartContext Doc - Gère le mapping et les résumés IA via Azure AI Foundry",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "summarize:sample": "node azure/summarize.js --sample jira",
    "sync-mapping": "node scripts/sync-mapping.js",
    "generate-icons": "node scripts/generate-icons.js",
    "test:pdf": "node scripts/test-pdf-encoding.js"
  },
  "keywords": [
    "chrome-extension",
    "documentation",
    "azure",
    "openai",
    "rag"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "form-data": "^4.0.0",
    "node-fetch": "^3.3.2",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.17.2",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
